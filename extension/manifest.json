{
  "manifest_version": 3,
  "name": "Aether – Knowledge Vault",
  "version": "1.0.0",
  "description": "Save any URL to your Aether vault. AI extracts, summarizes, and organizes it.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Save to Aether"
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "notifications",
    "alarms",
    "scripting"
  ],

  "host_permissions": [
    "https://aether.relayhaus.org/*",
    "http://localhost:8080/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://aether.relayhaus.org/*",
        "http://localhost:5173/*"
      ],
      "js": ["content/token-bridge.js"],
      "run_at": "document_idle"
    }
  ],

  "commands": {
    "save-current-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current page to Aether"
    }
  },

  "options_page": "options/options.html",

  "externally_connectable": {
    "matches": [
      "https://aether.relayhaus.org/*",
      "http://localhost:5173/*"
    ]
  }
}
